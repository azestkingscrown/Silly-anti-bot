# =====================================================================
# Discord Bot Configuration
# =====================================================================

# Bot Token (Get from https://discord.com/developers/applications)
DISCORD_TOKEN=your_bot_token_here

# Server/Guild Configuration
GUILD_ID=your_server_id_here
MUTED_ROLE_ID=your_muted_role_id_here

# Channel Configuration
APPEAL_CHANNEL_ID=your_appeal_channel_id_here
LOG_CHANNEL_ID=your_log_channel_id_here

# =====================================================================
# Image Detection Settings
# =====================================================================

# Similarity Threshold (0.0-1.0)
SIMILARITY_THRESHOLD=0.65

# =====================================================================
# Punishment Settings (Configurable)
# =====================================================================

# Punishment type for detected spam (mute, timeout, kick, ban)
PUNISHMENT_TYPE=mute

# Duration settings
MUTE_DURATION_DAYS=7
TIMEOUT_DURATION_MINUTES=60
BAN_DELETE_DAYS=1

# Progressive punishment per offense (first, second, third)
# Actions: mute, timeout, kick, ban
FIRST_OFFENSE_ACTION=mute
SECOND_OFFENSE_ACTION=timeout
THIRD_OFFENSE_ACTION=kick

# Image handling
AUTO_DELETE_IMAGE=true
AUTO_DELETE_DELAY=0

# Logging
LOG_DETECTIONS=true
LOG_APPEALS=true

# =====================================================================
# Bot Presence Configuration
# =====================================================================

# Bot Status (online, idle, do_not_disturb, invisible)
BOT_STATUS=online

# Bot Activity Type (playing, streaming, listening, watching)
BOT_ACTIVITY_TYPE=watching

# Bot Activity Text (what the bot shows it's doing)
# Examples: "for spam", "your server", "Discord", "the admins"
BOT_ACTIVITY_TEXT=for spam images

# =====================================================================
# Advanced Settings (Optional)
# =====================================================================

# Enable detailed logging
DEBUG_MODE=false

# Maximum image size for processing (pixels)
MAX_IMAGE_SIZE=1024

# Detection cache timeout in seconds
CACHE_TIMEOUT=3600

# Rate limiting for detection checks (per minute)
DETECTION_RATE_LIMIT=10

# Auto-cleanup old data after N days
AUTO_CLEANUP_DAYS=90

# Web Server Security
WEB_API_TOKEN=change-this-to-a-secure-token-in-production
